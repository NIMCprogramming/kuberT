# Copy this file to .env and edit as needed.

# Name of the local Kind cluster
KUBERT_CLUSTER_NAME=kubert

# Where to save user progress (default: ~/.kubert)
# KUBERT_STATE_DIR=

# Kind node image (default matches kind v0.27.0). Change if you use a different kind version.
KUBERT_NODE_IMAGE=kindest/node:v1.32.2
